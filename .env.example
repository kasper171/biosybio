# ── Supabase (obrigatório) ───────────────────────────────────────────────────
# URL do projeto — Dashboard Supabase → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_publica_ou_sb_publishable_...

# Mesmas variáveis para SSR / server functions (sem prefixo VITE_)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=sua_chave_publica_ou_sb_publishable_...

# Apenas no servidor — NUNCA exponha no cliente (Vercel → Environment Variables)
# Obrigatório para criar contas com segurança no servidor
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# ── Migrations de segurança (obrigatório em produção) ───────────────────────
# Execute no Supabase SQL Editor ou via `supabase db push`:
#   supabase/migrations/20260708120000_security_hardening.sql
#   supabase/migrations/20260708130000_security_complete.sql
