{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "byosy.bio" }],
      "destination": "https://www.byosy.bio/:path*",
      "permanent": true
    }
  ]
}
